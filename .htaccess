RewriteEngine On
# PASS Authorization header to PHP (important for SePay/OAuth)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# --- PHP SETTINGS: Increase upload limits ---
<IfModule mod_php7.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 64M
    php_value memory_limit 256M
</IfModule>
<IfModule mod_php.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 64M
    php_value memory_limit 256M
</IfModule>

# NO RewriteBase — Apache auto-detects from .htaccess directory
# Local: /kaishop_v2/  |  Production: /  — zero config needed
ErrorDocument 403 403.php
ErrorDocument 500 500.php
# ─── SECURITY: Block access to sensitive files and directories ───
<FilesMatch "\.(env|git|gitignore|sql|md|log|bak|swp|sh|bat)$">
    order allow,deny
    deny from all
</FilesMatch>

# Block access to sensitive directories
RewriteRule ^\.git(/|$) - [F,L]
RewriteRule ^\.env$ - [F,L]
RewriteRule ^config/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^core/ - [F,L]
RewriteRule ^app/ - [F,L]
RewriteRule ^csdl\.sql$ - [F,L]
RewriteRule ^docs/ - [F,L]
RewriteRule ^storage/ - [F,L]

# Disable directory listing
Options -Indexes

# --- SECURITY: Block common scraper/bot User-Agents ---
# Only apply this filter to public GET/HEAD requests.
# Business POST actions (purchase, login, deposit, profile updates, APIs)
# must always reach PHP so the app can validate them correctly.
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{REQUEST_METHOD} !PUT
RewriteCond %{REQUEST_METHOD} !PATCH
RewriteCond %{REQUEST_METHOD} !DELETE
RewriteCond %{REQUEST_URI} !^/(?:[^/]+/)?deploy\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/(?:[^/]+/)?api/(?:sepay/webhook|telegram/webhook|[A-Za-z0-9_-]{16,120}(?:/index\.php)?)$ [NC]
RewriteCond %{REQUEST_URI} !^/(?:[^/]+/)?product/[0-9]+/(?:quote|purchase)$ [NC]
RewriteCond %{REQUEST_URI} !^/(?:[^/]+/)?(?:login|register|password-reset)(?:/.*)?$ [NC]
RewriteCond %{REQUEST_URI} !^/(?:[^/]+/)?(?:deposit|deposit-create|deposit-bank|balance)(?:/.*)?$ [NC]
RewriteCond %{REQUEST_URI} !^/(?:[^/]+/)?(?:profile|password)(?:/.*)?$ [NC]
RewriteCond %{HTTP_USER_AGENT} (curl|wget|python|scrapy|httpclient|java|libwww|mechanize|phantom|headless|sqlmap|nikto|nmap|masscan) [NC]
RewriteRule ^ - [F,L]

# ─── SECURITY: Anti-hotlink for images ───
RewriteCond %{REQUEST_URI} \.(?:jpe?g|png|gif|webp|svg)$ [NC]
RewriteCond %{HTTP_REFERER} !^$ [NC]
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?localhost(?::[0-9]+)?/ [NC]
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?127\.0\.0\.1(?::[0-9]+)?/ [NC]
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?kaishop\.id\.vn/ [NC]
RewriteRule \.(?:jpe?g|png|gif|webp|svg)$ - [F,NC,L]

# ─── SECURITY: HTTP Security Headers ───
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Block clickjacking (only allow framing from same origin)
    Header always set X-Frame-Options "SAMEORIGIN"

    # Enable XSS filter in legacy browsers
    Header always set X-XSS-Protection "1; mode=block"

    # Control referrer info sent to other sites
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Prevent server version leaking
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ─── PERFORMANCE: Disable ETags (reduces unnecessary requests) ───
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# Compression for text assets
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript application/json image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 365 days"
    ExpiresByType application/javascript "access plus 365 days"
    ExpiresByType image/webp "access plus 365 days"
    ExpiresByType image/png "access plus 365 days"
    ExpiresByType image/jpeg "access plus 365 days"
    ExpiresByType image/gif "access plus 365 days"
    ExpiresByType image/svg+xml "access plus 365 days"
    ExpiresByType font/woff "access plus 365 days"
    ExpiresByType font/woff2 "access plus 365 days"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Redirect Trailing Slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# Handle Front Controller
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]

